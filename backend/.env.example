# Variables de entorno para HogarYa Backend
# Copia este archivo a .env y configura los valores reales

# Base de datos MongoDB (usa MongoDB Atlas para producción)
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/hogarya?retryWrites=true&w=majority

# JWT Secret (genera uno seguro, ej: openssl rand -base64 32)
JWT_SECRET=tu_clave_jwt_muy_segura_aqui

# Puerto del servidor
PORT=5000

# Ambiente (development/production)
NODE_ENV=development

# URL del frontend (para CORS en producción)
FRONTEND_URL=https://tu-dominio.vercel.app